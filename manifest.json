{
  "manifest_version": 2,
  "name": "Flax Blocker",
  "version": "1.0",
  "description": "Closes the tab created by redirects from flaxmovies",
  "permissions": [
    "storage",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "browser_action": {
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "@flaxblockerv1",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  }
}